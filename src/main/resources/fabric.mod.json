{
	"schemaVersion": 1,
	"id": "tilted",
	"version": "${version}",
	"name": "Tilted",
	"description": "Crossbows, unlimited crossbows, but no crossbows.",
	"authors": [
		"agmas",
		"PhantomPickle"
	],
	"license": "LGPL-3.0",
	"icon": "assets/tilted/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"org.agmas.Tilted"
		],
		"client": [
			"org.agmas.client.TiltedClient"
		],
		"fabric-datagen": [
			"org.agmas.client.TiltedDataGenerator"
		]
	},
	"mixins": [
		"tilted.mixins.json",
		{
			"config": "tilted.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": ">=1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}